# Copy to .streamlit/secrets.toml (local) or paste into Streamlit Cloud "Secrets".
# Real values live ONLY here / in Cloud Secrets — never in the repo.

openai_api_key = "sk-..."                 # the workshop OpenAI key
pinecone_api_key = "pcsk_..."             # Pinecone API key (free tier)
pinecone_index = "course-content"         # created automatically if missing

# Cloud Postgres (Neon / Supabase) connection
PG_HOST = "ep-xxxx-xxxx.us-east-2.aws.neon.tech"
PG_PORT = "5432"
PG_DB   = "course"
PG_USER = "course_app"
PG_PASSWORD = "..."
PG_SSLMODE = "require"

# MCP server (local Docker for now; e.g. http://localhost:8000/mcp)
mcp_server_url = "http://localhost:8000/mcp"

# Participant-code gate: SHA-256 of the code, never the code itself.
#   printf '%s' 'your-code' | shasum -a 256
workshop_passphrase_sha256 = "paste-the-64-char-hash-here"
